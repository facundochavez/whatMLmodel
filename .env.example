# Gemini API Keys for rotation
# Configure at least one API key. The system will rotate through available keys.
GEMINI_API_KEY_ONE=your_api_key_here
GEMINI_API_KEY_TWO=your_api_key_here
GEMINI_API_KEY_THREE=your_api_key_here
GEMINI_API_KEY_FOUR=your_api_key_here
GEMINI_API_KEY_FIVE=your_api_key_here

